rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /groups/{groupId} {

      // CREATE: unchanged
      allow create: if request.auth != null
                    && request.resource.data.members.hasAll([request.auth.uid])
                    && request.resource.data.members.size() == 1;

      // ✅ FIXED: Only members can read
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;

      // UPDATE: unchanged (your logic is solid)
      allow update: if request.auth != null
                    && (
                      request.auth.uid in resource.data.members
                      || (
                        request.resource.data.members.hasAll(resource.data.members)
                        && request.resource.data.members.size() == resource.data.members.size() + 1
                        && request.resource.data.members.hasAll([request.auth.uid])
                        && request.resource.data.inviteCode == resource.data.inviteCode
                        && request.resource.data.name == resource.data.name
                        && request.resource.data.createdBy == resource.data.createdBy
                      )
                    );

      // DELETE: unchanged
      allow delete: if false;

      // Subcollections
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
                           && isGroupMember(groupId);
      }
    }

    // ✅ FIXED: _meta locked down
    match /_meta/{docId} {
      allow read: if request.auth != null;

      // safest default: no public writes
      allow write: if false;
    }

    // Helper function (unchanged)
    function isGroupMember(groupId) {
      return request.auth.uid in
        get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }
  }
}
